;

--- Product Variety Insight ---

select distinct  product_name from products
; 

--- `Repeat Customers Insight` ---

select customer_id,
       count(order_id) as total_orders
from orders
group by customer_id
having count(order_id) > 1; 

--- Top Customer per City Insight ---

select *
from (
    select c.city,
           c.customer_name,
           sum(od.quantity * p.price) as revenue,
           rank() over (partition by c.city order by sum(od.quantity * p.price) desc) as rnk
    from customers c
    join orders o on c.customer_id = o.customer_id
    join order_details od on o.order_id = od.order_id
    join products p on od.product_id = p.product_id
    group by c.city, c.customer_name
) t
where rnk = 1;

--- Monthly Revenue Trend Insight ---

select month(order_date) as month,
       sum(total_amount) as revenue
from orders
group by month
order by month;

--- Most Preferred Product per Customer Insight --- 

select *
from (
    select c.customer_id,
           p.product_name,
           sum(od.quantity) as total_qty,
           rank() over (partition by c.customer_id order by sum(od.quantity) desc) as rnk
    from customers c
    join orders o on c.customer_id = o.customer_id
    join order_details od on o.order_id = od.order_id
    join products p on od.product_id = p.product_id
    group by c.customer_id, p.product_name
) t
where rnk = 1;

--- `High Value Customers (Total Spending) Insight` --- 

SELECT c.customer_id, SUM(od.quantity * p.price) AS total_spent
FROM orders o
join customers c on c.customer_id = o.customer_id
    join order_details od on o.order_id = od.order_id
    join products p on od.product_id = p.product_id
GROUP BY customer_id
ORDER BY total_spent DESC; 

--- Customer Order Frequency Insight ---

SELECT c.customer_id, COUNT(o.order_id) AS order_count
FROM orders o
join customers c on c.customer_id = o.customer_id
    join order_details od on o.order_id = od.order_id
    join products p on od.product_id = p.product_id
GROUP BY customer_id;

--- `Month-over-Month Revenue Change Insight` ---

SELECT month,
       revenue,
       LAG(revenue) OVER (ORDER BY month) AS prev_revenue
FROM (
    SELECT DATE_FORMAT(o.order_date, '%Y-%m') AS month,
           SUM(od.quantity * p.price)  AS revenue
    fROM orders o
join customers c on c.customer_id = o.customer_id
    join order_details od on o.order_id = od.order_id
    join products p on od.product_id = p.product_id
    GROUP BY month
) t;
